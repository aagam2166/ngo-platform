generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
    CITIZEN
    NGO_ADMIN
    VOLUNTEER
    SUPER_ADMIN
}

enum RequestStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         Role      @default(CITIZEN)
  firstName    String
  lastName     String
  phone        String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  requests         Request[]
  ngoProfile       NGO?
  volunteerProfile Volunteer?
  notifications    Notification[]
  comments         Comment[]

  @@index([email])
  @@index([role])
}

model NGO {
  id             String    @id @default(uuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  registrationNo String    @unique
  description    String?   @db.Text
  address        String
  city           String
  state          String
  isVerified     Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  requests  Request[]
  resources Resource[]
  volunteers NGOVolunteer[]
  VolunteerAssignments VolunteerAssignment[]
  joinRequests VolunteerJoinRequest[]
  VolunteerInterests VolunteerInterest[]
  resourceAllocations ResourceAllocation[]
}

model Volunteer {
  id          String    @id @default(uuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills      Json?
  bio         String?   @db.Text
  isAvailable Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  ngoMemberships NGOVolunteer[]

  assignments VolunteerAssignment[]
  joinRequests VolunteerJoinRequest[]
  interests VolunteerInterest[]
}

model Request {
  id           String        @id @default(uuid())
  citizenId    String
  citizen      User          @relation(fields: [citizenId], references: [id])
  ngoId        String?
  ngo          NGO?          @relation(fields: [ngoId], references: [id])
  title        String
  description  String        @db.Text
  category     String
  status       RequestStatus @default(PENDING)
  urgencyLevel Int           @default(1)
  address      String
  city         String
  state        String
  rejectionReason String? @db.Text
  assignments VolunteerAssignment[]
  VolunteerInterests VolunteerInterest[]
  ResourceAllocations ResourceAllocation[]
  statusLogs  RequestStatusLog[]
  comments    Comment[]
  reviewedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status])
  @@index([citizenId])
  @@index([ngoId])
}

model Resource {
  id          String    @id @default(uuid())
  ngoId       String
  ngo         NGO       @relation(fields: [ngoId], references: [id])
  name        String
  type        String
  quantity    Float
  unit        String?
  description String?   @db.Text
  allocations ResourceAllocation[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

}

model VolunteerAssignment {
  id          String    @id @default(uuid())
  requestId   String
  request     Request   @relation(fields: [requestId], references: [id])
  volunteerId String
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id])
  ngoId       String
  ngo         NGO       @relation(fields: [ngoId], references: [id])
  assignedBy  String
  assignedAt  DateTime  @default(now())
  status      String    @default("ASSIGNED")
  notes       String?   @db.Text
  updatedAt   DateTime  @updatedAt

  @@unique([requestId, volunteerId])
  @@index([volunteerId])
  @@index([requestId])
  @@index([ngoId])
}

model NGOVolunteer {
  id String @id @default(uuid())
  ngoId String
  ngo NGO @relation(fields: [ngoId], references: [id])
  volunteerId String
  volunteer Volunteer @relation(fields: [volunteerId], references: [id])
  joinedAt DateTime @default(now())
  isActive Boolean @default(true)

  @@unique([ngoId, volunteerId])
  @@index([ngoId])
  @@index([volunteerId])
}

model VolunteerJoinRequest {
  id          String    @id @default(uuid())
  volunteerId String
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  ngoId       String
  ngo         NGO       @relation(fields: [ngoId], references: [id], onDelete: Cascade)
  message     String?   @db.Text
  status      String    @default("PENDING")
  respondedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([volunteerId, ngoId])
  @@index([volunteerId])
  @@index([ngoId])
  @@index([status])
}

model VolunteerInterest {
  id          String    @id @default(uuid())
  volunteerId String
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  requestId   String
  request     Request   @relation(fields: [requestId], references: [id], onDelete: Cascade)
  ngoId       String
  ngo         NGO       @relation(fields: [ngoId], references: [id], onDelete: Cascade)
  message     String?   @db.Text
  status      String    @default("PENDING")
  respondedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([volunteerId, requestId])
  @@index([volunteerId])
  @@index([requestId])
  @@index([ngoId])
  @@index([status])
}

model ResourceAllocation {
  id          String   @id @default(uuid())
  resourceId  String
  resource    Resource @relation(fields: [resourceId], references: [id], onDelete: Restrict)
  requestId   String
  request     Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  ngoId       String
  ngo         NGO      @relation(fields: [ngoId], references: [id], onDelete: Restrict)
  quantity    Float
  notes       String?  @db.Text
  allocatedAt DateTime @default(now())
  allocatedBy String

  @@index([resourceId])
  @@index([requestId])
  @@index([ngoId])
}


model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, isRead])
}

model RequestStatusLog {
  id        String   @id @default(uuid())
  requestId String
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  status    String
  changedBy String
  note      String?
  createdAt DateTime @default(now())

  @@index([requestId])
}

model Comment {
  id        String   @id @default(uuid())
  requestId String
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requestId])
  @@index([authorId])
}
